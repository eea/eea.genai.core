<configure
  xmlns="http://namespaces.zope.org/zope"
  xmlns:genericsetup="http://namespaces.zope.org/genericsetup"
  i18n_domain="eea">

  <genericsetup:upgradeSteps
    source="*"
    destination="1.0"
    profile="eea.genai.core:default">

    <genericsetup:upgradeDepends
      title="Import all steps from eea.genai.core default profile"
      import_profile="eea.genai.core:default"
    />

  </genericsetup:upgradeSteps>

</configure>